# docker/demo.env — DEMO-ONLY credential values, committed on purpose.
#
# These are throwaway values for the localhost-only `make demo` /
# `make demo-cdc` stack (see docs/governance/security-posture.md). Compose no
# longer bakes them in as inline `:-default` fallbacks — every secret below
# is `${VAR:?...}` (required) in docker-compose.yml, and this file is the one
# place that supplies them for local dev via `--env-file docker/demo.env`
# (Makefile/scripts/demo.sh) and each service's `env_file:`. Point the stack
# at anything non-local by exporting real values instead of editing this
# file, or overriding it with your own `--env-file`.
BANK_DB_PASSWORD=LocalDev!Passw0rd
TOKENIZATION_SALT=change-me-local-only

# Ticket 18 (ADR 0006): Redpanda's built-in schema registry, internal
# listener — see docker-compose.yml redpanda service `--schema-registry-addr`.
SCHEMA_REGISTRY_URL=http://redpanda:8081
