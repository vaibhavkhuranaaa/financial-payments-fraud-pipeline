# Kafka / Event Hubs
# Local (Redpanda via docker compose): leave defaults.
# Azure Event Hubs: set BOOTSTRAP to <namespace>.servicebus.windows.net:9093,
# SECURITY_PROTOCOL=SASL_SSL, SASL_MECHANISM=PLAIN, SASL_USERNAME='$ConnectionString',
# SASL_PASSWORD=<Event Hubs connection string>.
KAFKA_BOOTSTRAP_SERVERS=localhost:19092
KAFKA_SECURITY_PROTOCOL=PLAINTEXT
KAFKA_SASL_MECHANISM=
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=
KAFKA_TOPIC_TRANSACTIONS=transactions
KAFKA_TOPIC_DLQ=transactions.dlq

# Producer replay
PRODUCER_EVENTS_PER_SEC=200
PRODUCER_INPUT_CSV=data/sample/transactions_sample.csv

# Tokenization (PAN hashing salt — any random string; rotate = new token space)
TOKENIZATION_SALT=change-me-local-only

# Redis online feature store
REDIS_HOST=localhost
REDIS_PORT=6379

# Paths
DELTA_ROOT=data/delta
MODEL_DIR=models

# Scoring service
SCORE_THRESHOLD_PATH=models/threshold.json

# Bank DB (core-banking system-of-record, Azure SQL Edge — ticket 06)
# Local (Docker Compose "demo" profile): leave defaults; connects as `sa` to
# a dedicated `frauddemo` database (auto-created by src.bank.db.bootstrap_database
# / src.bank.seed), all objects under the `bank` schema. A dedicated database
# (not `master`) is required from ticket 11 onward: SQL Server/SQL Edge CDC
# (sp_cdc_enable_db) can only be enabled on a user database.
BANK_DB_HOST=localhost
BANK_DB_PORT=1433
BANK_DB_USER=sa
BANK_DB_PASSWORD=LocalDev!Passw0rd
BANK_DB_NAME=frauddemo

# Seed input for src.bank.seed (defaults to the same sample the producer uses)
SEED_INPUT_CSV=data/sample/transactions_sample.csv

# Scorer loop (ticket 07): Kafka transactions -> POST /score -> bank DB
# SCORE_URL: local compose reaches the api container by its service name.
# ALERT_THRESHOLD: empty = use the /score response's own model threshold.
# SCORER_MAX_EVENTS: empty = run forever; set for bounded smoke/tests.
SCORE_URL=http://api:8000/score
ALERT_THRESHOLD=
SCORER_MAX_EVENTS=

# Fraud-ops dashboard (ticket 08)
# API_METRICS_URL: local compose reaches the api container by its service name;
# unreachable is fine — the latency tile just shows a waiting state.
# DASHBOARD_PORT: exposed port for the Dash app (http://localhost:8050).
API_METRICS_URL=http://api:8000/metrics
DASHBOARD_PORT=8050

# Observability overlay (ticket 13, `make demo OBS=1` / `make demo-cdc OBS=1`)
# LAG_EXPORTER_PORT: consumer-lag + bank-freshness exporter (Prometheus text).
# LAG_POLL_INTERVAL_S: seconds between backend polls.
# LAG_GROUPS: group:topic pairs to watch (default covers both demo modes).
LAG_EXPORTER_PORT=9105
LAG_POLL_INTERVAL_S=5
LAG_GROUPS=scorer:transactions,cdc-transformer:bankdb.frauddemo.bank.card_transactions

# Drift detection (ticket 17, v1.5b): off by default (0) — the obs profile's
# behavior is unchanged unless this is opted in. When > 0, the lag exporter
# runs a PSI check (src/pipeline/drift.py) against bank.scored_transactions
# every DRIFT_CHECK_INTERVAL_S seconds and publishes model_psi{feature}
# gauges. DRIFT_CHECK_LIMIT: how many recent scored_transactions rows to
# sample per check. Same env vars apply to `python -m src.pipeline.drift
# --check` run standalone.
DRIFT_CHECK_INTERVAL_S=0
DRIFT_CHECK_LIMIT=2000
